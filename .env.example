# ============================================================
# .env.example — Copia este archivo como ".env" y completa.
# NUNCA subas el archivo .env real a Git (.env está en .gitignore).
#
# Cambia LLM_PROVIDER para elegir el proveedor activo.
# Tras cambiar de proveedor borra .llm_cache.json para no
# mezclar respuestas de modelos distintos.
# ============================================================


# ── Proveedor activo ─────────────────────────────────────────
# Valores: gemini | groq | openai
LLM_PROVIDER=gemini


# ── Modelo (opcional) ────────────────────────────────────────
# Si no se define, se usa el modelo por defecto del proveedor:
#   gemini → gemini-2.5-flash
#   groq   → llama-3.3-70b-versatile
#   openai → gpt-4o-mini
#
# LLM_MODEL=gemini-2.5-flash


# ════════════════════════════════════════════════════════════
# OPCIÓN 1 — Google Gemini (por defecto, gratuito con cuota)
# Genera tu clave en: https://aistudio.google.com/
# Plan gratuito: ~1 500 req/día · Calidad en español: muy buena
# ════════════════════════════════════════════════════════════
GEMINI_API_KEY=tu-clave-aquí

# Ejemplos de modelos Gemini disponibles:
#   gemini-2.5-flash   ← recomendado (rápido, gratuito)
#   gemini-2.5-pro     ← mayor calidad, más lento
#   gemini-1.5-flash


# ════════════════════════════════════════════════════════════
# OPCIÓN 2 — Groq (recomendado para experimentos masivos)
# Registro gratuito sin tarjeta: https://console.groq.com
# Plan gratuito: ~14 400 req/día · 30 req/min
# ════════════════════════════════════════════════════════════
# LLM_PROVIDER=groq
# OPENAI_API_KEY=u-clave-aquí
# OPENAI_BASE_URL=https://api.groq.com/openai/v1

# Modelos Groq recomendados:
#   llama-3.3-70b-versatile   ← mejor coherencia semántica (recomendado)
#   llama-3.1-8b-instant      ← más rápido, menor calidad
#   mixtral-8x7b-32768


# ════════════════════════════════════════════════════════════
# OPCIÓN 3 — OpenAI nativo
# https://platform.openai.com/
# ════════════════════════════════════════════════════════════
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-REEMPLAZA_CON_TU_CLAVE_DE_OPENAI
# (OPENAI_BASE_URL no es necesario para la API oficial)

# Modelos OpenAI recomendados:
#   gpt-4o-mini   ← económico, buena calidad
#   gpt-4o        ← máxima calidad
