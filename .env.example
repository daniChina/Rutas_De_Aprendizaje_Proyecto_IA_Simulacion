# ============================================================
# .env.example — Copia este archivo como ".env" y completa
#                con tus claves reales.
# NUNCA subas el archivo .env real a Git (.env está en .gitignore).
#
# FUNCIONAMIENTO:
#   - LLM_PROVIDER      → proveedor principal (el que se usa primero)
#   - LLM_FALLBACK_PROVIDER → proveedor de respaldo (se activa automáticamente
#                             cuando el principal agota su cuota)
# ============================================================


# ── Proveedor activo y fallback ──────────────────────────────
# Valores válidos: gemini | groq | openai
LLM_PROVIDER=groq
LLM_FALLBACK_PROVIDER=gemini


# ── Modelos (opcional) ───────────────────────────────────────
# Si no se definen, se usan los modelos por defecto:
#   gemini → gemini-2.5-flash
#   groq   → llama-3.3-70b-versatile
#   openai → gpt-4o-mini
#
# LLM_MODEL=llama-3.3-70b-versatile
# LLM_FALLBACK_MODEL=gemini-2.5-flash


# ════════════════════════════════════════════════════════════
# OPCIÓN 1 — Google Gemini
# Genera tu clave en: https://aistudio.google.com/
# Plan gratuito: ~1 500 req/día · Calidad en español: muy buena
# ════════════════════════════════════════════════════════════
GEMINI_API_KEY=tu-clave-gemini-aquí

# Modelos Gemini disponibles:
#   gemini-2.5-flash   ← recomendado (rápido, gratuito)
#   gemini-2.5-pro     ← mayor calidad, más lento
#   gemini-1.5-flash


# ════════════════════════════════════════════════════════════
# OPCIÓN 2 — Groq
# Registro gratuito sin tarjeta: https://console.groq.com
# Plan gratuito: ~100 000 tokens/día · 30 req/min
# ════════════════════════════════════════════════════════════
OPENAI_API_KEY=tu-clave-groq-aquí
OPENAI_BASE_URL=https://api.groq.com/openai/v1

# Modelos Groq recomendados:
#   llama-3.3-70b-versatile   ← mejor coherencia semántica (recomendado)
#   llama-3.1-8b-instant      ← más rápido, menor calidad
#   mixtral-8x7b-32768


# ════════════════════════════════════════════════════════════
# OPCIÓN 3 — OpenAI nativo (opcional)
# https://platform.openai.com/
# ════════════════════════════════════════════════════════════
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-tu-clave-openai-aquí
# OPENAI_BASE_URL no es necesario para la API oficial de OpenAI

# Modelos OpenAI recomendados:
#   gpt-4o-mini   ← económico, buena calidad
#   gpt-4o        ← máxima calidad
