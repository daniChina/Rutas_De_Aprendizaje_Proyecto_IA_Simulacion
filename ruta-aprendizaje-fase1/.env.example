# --- Proveedor LLM (Fase 2) ---
OPENAI_API_KEY=sk-REEMPLAZA_CON_TU_CLAVE

# Modelo a usar (default: gpt-4o-mini)
# Opciones: gpt-4o, gpt-4o-mini, gpt-4-turbo
OPENAI_MODEL=gpt-4o-mini

# URL base alternativa para APIs compatibles (Groq, Ollama, Azure).
# Dejar vacío para usar la API oficial de OpenAI.
# OPENAI_BASE_URL=
